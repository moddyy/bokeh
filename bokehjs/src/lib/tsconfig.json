{
  "compilerOptions": {
    "strictPropertyInitialization": false,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["google.maps"],
    "paths": {
      "*": ["./*"]
    },
    "outDir": "../../build/js/lib",
    "rootDir": ".",
    "rootDirs": [".", "../../build/dts/"],
    "incremental": true,
    "tsBuildInfoFile": "../../build/js/bokehjs.tsbuildinfo"
  },
  "extends": "../../tsconfig.base",
  "include": ["./**/*.ts", "../../build/dts"]
}
